# rrlm reads model credentials from your Pi config (~/.pi/agent/), so for most
# setups you do NOT need a .env file at all -- configure your models in Pi.
#
# This file is only useful for:
#   - the no-Pi path: running against OpenRouter directly
#     (e.g. rrlm-solve --main openrouter/qwen/qwen3.6-27b ...)
#   - OpenRouter cost reconciliation (authoritative per-call USD from the
#     generation endpoint) when you run hosted OpenRouter models.
#
# Copy to .env and fill in if you need either. Never commit .env.
OPENROUTER_API_KEY=sk-or-...
